# API Keys for Agent Observability Lab
# Copy this file to .env and fill in your API keys

# Model provider
# Set either OPENAI_API_KEY or ANTHROPIC_API_KEY.
# If both are set, the agent will prefer OpenAI.

# OpenAI (optional)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic (optional)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Braintrust (REQUIRED for observability - FREE, no credit card required)
# Sign up and get your FREE key at: https://www.braintrust.dev/
BRAINTRUST_API_KEY=your-braintrust-api-key-here

# Braintrust parent/project identifier (REQUIRED)
# Preferred variable: BRAINTRUST_PARENT
# Expected format: project_name:your-project-name
#
# Examples:
#   project_name:simple-agent-observability
#   project_name:dsan6725-my-cool-final-project
#
# Backward compatibility:
# - You can still set BRAINTRUST_PROJECT.
# - If you use a plain project name like DSAN6725, the app will normalize it
#   to project_name:DSAN6725 before exporting traces.
BRAINTRUST_PARENT=project_name:simple-agent-observability

# MCP server for Problem 2 (optional)
# Defaults to Context7 if not set.
MCP_SERVER_URL=https://mcp.context7.com/mcp
